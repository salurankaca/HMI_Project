         <property name="styleSheet">
          <string notr="true">QPushButton {
    /* Gradien Merah */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
        stop:0 #ff5f6d, stop:1 #e74c3c);
    
    color: white;
    font-weight: bold;
    font-size: 14px;
    border: none;

    /* Bentuk setengah lingkaran bawah (asumsi lebar 100px) */
    border-bottom-left-radius: 50px;
    border-bottom-right-radius: 50px;

    /* Efek 3D: Garis terang tipis di atas, bayangan tebal di bawah */
    border-top: 1px solid #ff9a9e;
    border-bottom: 5px solid #96281b;
}

QPushButton:hover {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
        stop:0 #ff6b6b, stop:1 #ff4757);
}

QPushButton:pressed {
    border-bottom: 1px solid #96281b;
    padding-top: 4px;
}</string>
