         <property name="styleSheet">
          <string notr="true">QPushButton {
    /* Gradien untuk efek pencahayaan dari atas ke bawah */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
        stop:0 #34e89e, stop:1 #27ae60);
    
    color: white;
    font-weight: bold;
    font-size: 14px;
    border: none;

    /* Bentuk setengah lingkaran atas (asumsi lebar 100px) */
    border-top-left-radius: 50px;
    border-top-right-radius: 50px;

    /* Efek 3D: Garis terang di atas, bayangan gelap di bawah */
    border-top: 2px solid #a8ff78;
    border-bottom: 4px solid #1a5e3a; 
}

QPushButton:hover {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, 
        stop:0 #40ffaf, stop:1 #2ecc71);
}

QPushButton:pressed {
    /* Efek tombol tertekan: Hilangkan bayangan bawah, tambah padding */
    border-bottom: 1px solid #1a5e3a;
    padding-top: 4px;
}</string>
